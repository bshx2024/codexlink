{
  "version": "1.0",
  "ai": {
    "provider": "openai",
    "model": "mimo-v2-pro",
    "api_key_env": "MIMO_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 1.0,
    "analysis_concurrency": 2,
    "enrichment_concurrency": 1,
    "languages": [
      "zh",
      "en"
    ],
    "base_url": "https://api.xiaomimimo.com/v1"
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_enabled": true,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "your_email@qq.com",
    "password_env": "EMAIL_PASSWORD",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "anthropics",
        "repo": "anthropic-sdk-python",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "google-gemini",
        "repo": "gemini-cli",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "microsoft",
        "repo": "autogen",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "langchain-ai",
        "repo": "langchain",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "run-llama",
        "repo": "llama_index",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "modelcontextprotocol",
        "repo": "python-sdk",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 80
    },
    "rss": [
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/news/rss.xml",
        "enabled": true,
        "category": "ai-official"
      },
      {
        "name": "Anthropic News",
        "url": "https://www.anthropic.com/news/rss.xml",
        "enabled": false,
        "category": "ai-official",
        "disabled_reason": "No official working RSS found on 2026-05-30"
      },
      {
        "name": "Google AI Blog",
        "url": "https://blog.google/technology/ai/rss/",
        "enabled": true,
        "category": "ai-official"
      },
      {
        "name": "DeepMind Blog",
        "url": "https://deepmind.google/discover/blog/feed",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "ai-dev"
      },
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "The Batch - DeepLearning.AI",
        "url": "https://www.deeplearning.ai/the-batch/feed/",
        "enabled": false,
        "category": "ai-news",
        "disabled_reason": "No official working RSS found on 2026-05-30"
      },
      {
        "name": "Import AI",
        "url": "https://jack-clark.net/feed/",
        "enabled": true,
        "category": "ai-analysis"
      },
      {
        "name": "Ben's Bites",
        "url": "https://www.bensbites.com/feed",
        "enabled": true,
        "category": "ai-news"
      },
      {
        "name": "Latent Space",
        "url": "https://www.latent.space/feed",
        "enabled": true,
        "category": "ai-dev"
      },
      {
        "name": "Papers with Code",
        "url": "https://paperswithcode.com/rss",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "MIT AI News",
        "url": "https://news.mit.edu/topic/mitartificial-intelligence2-rss.xml",
        "enabled": false,
        "category": "ai-research",
        "disabled_reason": "RSS URL is valid, but MIT returns 403 to Python/httpx requests as of 2026-05-30"
      },
      {
        "name": "BAAI Blog",
        "url": "https://www.baai.ac.cn/en/blog/feed",
        "enabled": false,
        "category": "ai-cn"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 50
        },
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 80
        },
        {
          "subreddit": "singularity",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 150
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": true,
      "channels": [
        {
          "channel": "aigc1024",
          "enabled": true,
          "fetch_limit": 20
        },
        {
          "channel": "openaipro",
          "enabled": false,
          "fetch_limit": 20
        }
      ]
    },
    "twitter": {
      "enabled": false,
      "apify_token_env": "APIFY_TOKEN",
      "users": [
        "OpenAI",
        "AnthropicAI",
        "GoogleDeepMind",
        "karpathy",
        "sama",
        "AndrewYNg",
        "huggingface",
        "LangChainAI",
        "swyx"
      ],
      "fetch_limit": 20,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 10
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": [
        "All",
        "Python",
        "TypeScript"
      ],
      "keywords": [
        "ai",
        "llm",
        "agent",
        "rag",
        "mcp",
        "diffusion",
        "multimodal",
        "inference"
      ],
      "min_stars": 20,
      "max_items": 30
    }
  },
  "filtering": {
    "ai_score_threshold": 6.5,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "text": "Horizon AI?? #{date}\n\n#{summary}"
    },
    "headers": ""
  },
  "competitive_intelligence": {
    "enabled": true,
    "competitors": [
      {
        "name": "Anthropic",
        "slug": "anthropic",
        "enabled": true,
        "tags": [
          "llm-api",
          "direct-competitor"
        ],
        "signal_types": [
          "product_launch",
          "pricing_change",
          "technical_release",
          "partnership",
          "funding",
          "leadership"
        ],
        "sources": {
          "rss": [],
          "github_repos": [
            "anthropics/claude-code",
            "anthropics/anthropic-sdk-python",
            "anthropics/anthropic-quickstarts"
          ],
          "github_users": [
            "anthropics"
          ],
          "twitter_users": [
            "AnthropicAI",
            "claudeai",
            "darioamodei"
          ],
          "reddit_subreddits": [
            "Anthropic",
            "ClaudeAI"
          ],
          "news_keywords": [
            "Anthropic Claude",
            "Claude API",
            "Anthropic pricing"
          ],
          "web_pages": [
            "https://www.anthropic.com/pricing",
            "https://docs.anthropic.com/en/docs/quickstart"
          ],
          "telegram_channels": []
        }
      },
      {
