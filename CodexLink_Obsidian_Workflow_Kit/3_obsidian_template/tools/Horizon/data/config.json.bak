    "producthunt": {
      "enabled": false,
      "topics": [
        "artificial-intelligence",
        "developer-tools"
      ],
      "companies": [
        "openai",
        "anthropic",
        "mistral-ai"
      ],
      "fetch_top_daily": 20
    },
    "googlenews": {
      "enabled": true,
      "keywords": [
        "LLM API pricing war",
        "AI startup funding",
        "large language model",
        "AI agent platform"
      ],
      "max_items_per_keyword": 5,
      "language": "en",
      "region": "US"
    },
    "web_monitoring": {
      "enabled": false,
      "targets": [
        {
          "url": "https://openai.com/pricing",
          "name": "OpenAI Pricing",
          "enabled": true,
          "selector": "",
          "keywords": [
            "price",
            "price change",
            "new tier",
            "gpt",
            "o3"
          ]
        },
        {
          "url": "https://www.anthropic.com/pricing",
          "name": "Anthropic Pricing",
          "enabled": true,
          "selector": "",
          "keywords": [
            "price",
            "price change",
            "claude",
            "new"
          ]
        },
        {
          "url": "https://ai.google.dev/pricing",
          "name": "Google AI Pricing",
